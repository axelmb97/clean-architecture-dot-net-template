{
  "$schema": "http://json.schemastore.org/launchsettings.json",
  "iisSettings": {
    "windowsAuthentication": false,
    "anonymousAuthentication": true,
    "iisExpress": {
      "applicationUrl": "http://localhost:59004",
      "sslPort": 44355
    }
  },
  "profiles": {
    "IIS Local": {
      "commandName": "IISExpress",
      "launchBrowser": true,
      "launchUrl": "app-name/swagger",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Local"
      }
    },
    "Local": {
      "commandName": "Project",
      "launchBrowser": false,
      "launchUrl": "app-name/swagger",
      "applicationUrl": "http://localhost:5043",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Local"
      }
    },
    "IIS Testing": {
      "commandName": "IISExpress",
      "launchBrowser": true,
      "launchUrl": "app-name/swagger",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Testing"
      }
    },
    "Testing": {
      "commandName": "Project",
      "launchBrowser": false,
      "launchUrl": "app-name/swagger",
      "applicationUrl": "http://localhost:5043",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Testing"
      }
    }
  }
}
