{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "server=localhost;port=3306;database=time-tracker-db;user=time-tracker-user;password=time-tracker-password"
  },
  "EncriptionConfigs": {
    "Key": "esta es mi key por ahora",
    "Salt": "este es mi salt por ahora",
    "IVSize": "16"
  },
  "TokenConfigs": {
    "SecretKey": "7fB9Kx2PqR8vN4WmEJcD6ZLhA3sUeYH0",
    "ExpiresIn": 3600,
    "Issuer": "Time tracker",
    "Audience": "account"
  }
}
